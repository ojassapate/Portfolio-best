# Required environment variables
# Copy this file to .env.local and fill in your values

# Neon PostgreSQL connection string
# Get yours at https://console.neon.tech (free tier available)
DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require

# Password for the portfolio edit mode (choose any password you want)
EDIT_PASSWORD=your_secure_password_here
